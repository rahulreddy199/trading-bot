# Environment
.env
venv/
__pycache__/
*.pyc

# State files (generated at runtime)
state/*.json
state/*.csv
state/*.log
state/conservative/*.json
state/conservative/*.csv
state/growth/*.json
state/growth/*.csv
state/shared/*.json
state/shared/*.md
!state/shared/report_daily_*.md
!state/shared/report_weekly_*.md
state/locks/
state/logs/
!state/.gitkeep
!state/**/.gitkeep

# Journal entries (generated at runtime)
journal/*.md
!journal/2026-*.md
journal/*.log
!journal/.gitkeep

# Strategy snapshots (generated at runtime)
config/strategy_history/

# Backups (generated at runtime)
backups/


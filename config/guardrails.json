{
  "version": "1.1",
  "description": "Safety guardrails for autonomous strategy tuning (growth bot)",
  "min_trades_before_tuning": 30,
  "tuning_cooldown_weeks": 2,
  "max_parameters_changed_per_cycle": 2,
  "require_consecutive_underperformance_weeks": 3,
  "parameters": {
    "risk_per_trade": {
      "path": "regime.full_risk.risk_per_trade",
      "baseline": 0.0075,
      "min": 0.005,
      "max": 0.02,
      "max_step": 0.002
    },
    "risk_per_trade_reduced": {
      "path": "regime.reduced_risk.risk_per_trade",
      "baseline": 0.004,
      "min": 0.003,
      "max": 0.01,
      "max_step": 0.001
    },
    "trailing_atr_multiplier": {
      "path": "exit.trailing_atr_multiplier",
      "baseline": 3.0,
      "min": 2.0,
      "max": 4.0,
      "max_step": 0.3
    },
    "atr_stop_multiplier": {
      "path": "stop.atr_stop_multiplier",
      "baseline": 2.5,
      "min": 1.5,
      "max": 3.5,
      "max_step": 0.25
    },
    "phase_protected_r": {
      "path": "exit.phase_protected_r",
      "baseline": 1.5,
      "min": 1.0,
      "max": 2.5,
      "max_step": 0.25
    },
    "phase_trailing_r": {
      "path": "exit.phase_trailing_r",
      "baseline": 2.5,
      "min": 1.5,
      "max": 4.0,
      "max_step": 0.5
    },
    "time_stop_bars": {
      "path": "exit.time_stop_bars",
      "baseline": 10,
      "min": 5,
      "max": 15,
      "max_step": 2
    }
  },
  "tuning_enabled": false,
  "tuning_enabled_note": "Set to true only after 30+ paper trades confirm fills match expectations",
  "kill_switch": false,
  "max_monthly_api_spend_usd": 10.0,
  "drawdown_circuit_breaker": {
    "max_drawdown_pct": 15.0,
    "action": "risk_off",
    "alert": true,
    "description": "If portfolio drawdown exceeds this threshold, halt all new entries and alert"
  }
}
